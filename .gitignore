# === FritzTrack4U .gitignore ===
# WICHTIG: Niemals echte Zugangsdaten oder persoenliche Daten pushen!

# Echte Konfiguration mit Passwoertern/IPs/MACs - NIE committen!
config.json
*.local.json

# Datenbank mit Bewegungsverlauf (persoenliche Daten)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
fritzgps_verlauf.db
fritztrack_history.db

# Fingerprints (enthalten Wohnungs-Layout)
fingerprints.json
*_fingerprints.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Logs
*.log
logs/

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Interne Strategie-/Kontakt-Entwuerfe (nicht oeffentlich)
docs/AVM-Kontakt-Entwurf.md

# Diagnose-/Test-Skripte und Dumps mit echten Credentials/IPs/MACs - NIE committen!
_*.py
_*.json
_*.out
monitor.py

# Reverse-Engineering-Rohdaten/Beweis-Dossiers (enthalten echte Box-IPs, MACs, Topologie)
# Vor Veroeffentlichung muessten diese anonymisiert werden.
MULTI-FRITZBOX-ORTUNGSMODELL.md
MESH-RSSI-PRUEFPROTOKOLL.md
AVM-MESH-STEERING-MECHANIK.md
AVM-WSS-REVERSE-ENGINEERING.md
